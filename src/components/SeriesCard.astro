---
import type { CollectionEntry } from 'astro:content';
import { getSeriesUrl } from '../lib/urls';

interface Props {
  series: CollectionEntry<'series'>;
  postCount: number;
}

const { series, postCount } = Astro.props;
const { title, description, topic } = series.data;

// Resolve the series URL using the topic ID and the series Slug
const topicSlug = typeof topic === 'object' && 'id' in topic ? topic.id : String(topic);
const seriesSlug = series.id.split('/').pop() || '';
const url = getSeriesUrl(topicSlug, seriesSlug);
---

<a href={url} class="series-card" id={`series-card-${series.id.replace('/', '-')}`}>
  <div class="stack-effect">
    <div class="stack-layer layer-3"></div>
    <div class="stack-layer layer-2"></div>
    <div class="card-body">
      <div class="badge-row">
        <span class="badge series-badge">Series</span>
        <span class="badge-post-count">{postCount} {postCount === 1 ? 'part' : 'parts'}</span>
      </div>
      <h3 class="series-title">{title}</h3>
      <p class="series-description">{description}</p>
      
      <div class="card-footer">
        <span class="view-series">View series &rarr;</span>
      </div>
    </div>
  </div>
</a>

<style>
  .series-card {
    display: block;
    position: relative;
    padding-top: 12px; /* Leaves room for stack effect offset */
  }

  /* Stacked card visual effect */
  .stack-effect {
    position: relative;
    z-index: 1;
  }

  .stack-layer {
    position: absolute;
    inset: 0;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: var(--transition-normal);
  }

  .layer-3 {
    transform: translateY(-8px) scale(0.95);
    opacity: 0.4;
    z-index: -2;
  }

  .layer-2 {
    transform: translateY(-4px) scale(0.975);
    opacity: 0.7;
    z-index: -1;
  }

  .card-body {
    position: relative;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    box-shadow: var(--shadow-md);
    z-index: 2;
    transition: var(--transition-normal);
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 200px;
  }

  .badge-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .series-badge {
    background-color: var(--accent-light);
    color: var(--accent-color);
    border-color: rgba(99, 102, 241, 0.2);
  }

  .badge-post-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .series-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.50rem;
    color: var(--text-primary);
  }

  .series-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-color);
  }

  /* Hover states */
  .series-card:hover .card-body {
    border-color: var(--accent-color);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg), var(--shadow-accent);
  }

  .series-card:hover .layer-2 {
    transform: translateY(-8px) scale(0.98);
    opacity: 0.8;
  }

  .series-card:hover .layer-3 {
    transform: translateY(-12px) scale(0.96);
    opacity: 0.5;
  }

  .series-card:hover .view-series {
    text-decoration: underline;
  }
</style>
