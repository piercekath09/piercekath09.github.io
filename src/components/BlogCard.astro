---
import type { CollectionEntry } from 'astro:content';
import { getBlogUrl } from '../lib/urls';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, cover } = post.data;
const url = getBlogUrl(post);

// Calculate reading time based on post body
const words = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(words / 200));

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<a href={url} class="blog-card" id={`blog-card-${post.id.replace(/\//g, '-')}`}>
  {cover && (
    <div class="card-cover-container">
      <img src={cover} alt={title} class="card-cover-img" loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <div class="card-meta">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <span class="meta-dot">&bull;</span>
      <span>{readingTime} min read</span>
    </div>
    
    <h3 class="blog-title">{title}</h3>
    <p class="blog-description">{description}</p>
    
    {tags && tags.length > 0 && (
      <div class="tags-container">
        {tags.slice(0, 3).map(tag => (
          <span class="tag-badge">#{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: var(--transition-normal);
    height: 100%;
  }

  .card-cover-container {
    height: 180px;
    width: 100%;
    overflow: hidden;
  }

  .card-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-normal);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-dot {
    color: var(--border-color);
  }

  .blog-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    color: var(--text-primary);
    transition: var(--transition-fast);
  }

  .blog-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tag-badge {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    background-color: var(--bg-color);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }

  /* Hover Effects */
  .blog-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-color);
    box-shadow: var(--shadow-lg), var(--shadow-accent);
  }

  .blog-card:hover .blog-title {
    color: var(--accent-color);
  }

  .blog-card:hover .card-cover-img {
    transform: scale(1.05);
  }
</style>
